<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Системная информация {{ ansible_hostname }}</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            margin: 0;
            padding: 20px;
            min-height: 100vh;
        }
        .container {
            max-width: 1000px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }
        h1 {
            text-align: center;
            font-size: 2.5em;
            margin-bottom: 30px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            border-bottom: 2px solid rgba(255,255,255,0.3);
            padding-bottom: 20px;
        }
        .server-name {
            text-align: center;
            font-size: 1.5em;
            margin-bottom: 30px;
            color: #ffd700;
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }
        .stat-card {
            background: rgba(255,255,255,0.15);
            border-radius: 15px;
            padding: 20px;
            transition: transform 0.3s;
            border: 1px solid rgba(255,255,255,0.2);
        }
        .stat-card:hover {
            transform: translateY(-5px);
            background: rgba(255,255,255,0.2);
        }
        .stat-title {
            font-size: 1.2em;
            margin-bottom: 15px;
            color: #ffd700;
            border-bottom: 1px solid rgba(255,255,255,0.3);
            padding-bottom: 10px;
        }
        .stat-content {
            font-size: 1.1em;
            line-height: 1.8;
        }
        .stat-content p {
            margin: 10px 0;
            display: flex;
            align-items: center;
        }
        .stat-icon {
            font-size: 1.5em;
            margin-right: 15px;
            width: 30px;
            text-align: center;
        }
        .label {
            color: #aaa;
            min-width: 80px;
        }
        .value {
            font-weight: bold;
            color: white;
        }
        .footer {
            text-align: center;
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.3);
            font-size: 0.9em;
            color: rgba(255,255,255,0.7);
        }
        .progress-bar {
            width: 100%;
            height: 20px;
            background: rgba(0,0,0,0.3);
            border-radius: 10px;
            overflow: hidden;
            margin-top: 10px;
        }
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #4CAF50, #8BC34A);
            border-radius: 10px;
            transition: width 0.3s;
        }
        .disk-info {
            margin-top: 10px;
        }
        .disk-details {
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🔧 Системная информация сервера</h1>
        <div class="server-name">
            🖥️ {{ ansible_hostname }} ({{ ansible_default_ipv4.address }})
        </div>

        <div class="stats-grid">
            <!-- CPU Information -->
            <div class="stat-card">
                <div class="stat-title">
                    <span class="stat-icon">⚡</span> Процессор (CPU)
                </div>
                <div class="stat-content">
                    <p><span class="label">Модель:</span> <span class="value">{{ ansible_processor[1] | default(ansible_processor[0]) }}</span></p>
                    <p><span class="label">Ядер:</span> <span class="value">{{ ansible_processor_cores }} физических / {{ ansible_processor_vcpus }} виртуальных</span></p>
                    <p><span class="label">Архитектура:</span> <span class="value">{{ ansible_architecture }}</span></p>
                </div>
            </div>

            <!-- RAM Information -->
            <div class="stat-card">
                <div class="stat-title">
                    <span class="stat-icon">💾</span> Оперативная память (RAM)
                </div>
                <div class="stat-content">
                    {% set mem_total_mb = ansible_memtotal_mb %}
                    {% set mem_free_mb = ansible_memfree_mb %}
                    {% set mem_used_mb = ansible_memtotal_mb - ansible_memfree_mb %}
                    {% set mem_used_percent = (mem_used_mb / mem_total_mb * 100) | round(1) %}
                    
                    <p><span class="label">Всего:</span> <span class="value">{{ (mem_total_mb / 1024) | round(2) }} GB</span></p>
                    <p><span class="label">Свободно:</span> <span class="value">{{ (mem_free_mb / 1024) | round(2) }} GB</span></p>
                    <p><span class="label">Используется:</span> <span class="value">{{ (mem_used_mb / 1024) | round(2) }} GB ({{ mem_used_percent }}%)</span></p>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: {{ mem_used_percent }}%;"></div>
                    </div>
                </div>
            </div>

            <!-- First HDD Information -->
            <div class="stat-card">
                <div class="stat-title">
                    <span class="stat-icon">💽</span> Первый жесткий диск
                </div>
                <div class="stat-content">
                    {% set first_mount = ansible_mounts | selectattr('mount', 'equalto', '/') | first %}
                    {% if first_mount %}
                        {% set disk_total = first_mount.size_total %}
                        {% set disk_available = first_mount.size_available %}
                        {% set disk_used = disk_total - disk_available %}
                        {% set disk_used_percent = (disk_used / disk_total * 100) | round(1) %}
                        
                        <p><span class="label">Устройство:</span> <span class="value">{{ first_mount.device }}</span></p>
                        <p><span class="label">Точка монт.:</span> <span class="value">{{ first_mount.mount }}</span></p>
                        <p><span class="label">Файловая с-ма:</span> <span class="value">{{ first_mount.fstype }}</span></p>
                        <div class="disk-info">
                            <div class="disk-details">
                                <span>Всего:</span>
                                <span class="value">{{ (disk_total / 1024 / 1024 / 1024) | round(2) }} GB</span>
                            </div>
                            <div class="disk-details">
                                <span>Использовано:</span>
                                <span class="value">{{ (disk_used / 1024 / 1024 / 1024) | round(2) }} GB</span>
                            </div>
                            <div class="disk-details">
                                <span>Свободно:</span>
                                <span class="value">{{ (disk_available / 1024 / 1024 / 1024) | round(2) }} GB</span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: {{ disk_used_percent }}%;"></div>
                            </div>
                        </div>
                    {% else %}
                        <p>Информация о диске недоступна</p>
                    {% endif %}
                </div>
            </div>

            <!-- Network Information -->
            <div class="stat-card">
                <div class="stat-title">
                    <span class="stat-icon">🌐</span> Сетевые интерфейсы
                </div>
                <div class="stat-content">
                    <p><span class="label">IPv4:</span> <span class="value">{{ ansible_default_ipv4.address }}</span></p>
                    <p><span class="label">Маска:</span> <span class="value">{{ ansible_default_ipv4.netmask }}</span></p>
                    <p><span class="label">Шлюз:</span> <span class="value">{{ ansible_default_ipv4.gateway }}</span></p>
                    {% if ansible_default_ipv6 is defined %}
                    <p><span class="label">IPv6:</span> <span class="value">{{ ansible_default_ipv6.address }}</span></p>
                    {% endif %}
                </div>
            </div>

            <!-- Additional System Info -->
            <div class="stat-card">
                <div class="stat-title">
                    <span class="stat-icon">📊</span> Дополнительная информация
                </div>
                <div class="stat-content">
                    <p><span class="label">ОС:</span> <span class="value">{{ ansible_distribution }} {{ ansible_distribution_version }}</span></p>
                    <p><span class="label">Ядро:</span> <span class="value">{{ ansible_kernel }}</span></p>
                    <p><span class="label">Время работы:</span> <span class="value">{{ ansible_uptime_seconds | default(0) | int // 86400 }}д {{ (ansible_uptime_seconds | default(0) | int % 86400) // 3600 }}ч</span></p>
                    <p><span class="label">Дата:</span> <span class="value">{{ ansible_date_time.date }}</span></p>
                    <p><span class="label">Время:</span> <span class="value">{{ ansible_date_time.time }}</span></p>
                </div>
            </div>

            <!-- Mount points -->
            <div class="stat-card">
                <div class="stat-title">
                    <span class="stat-icon">📂</span> Точки монтирования
                </div>
                <div class="stat-content">
                    {% for mount in ansible_mounts[:3] %}
                        <p style="font-size: 0.9em;">
                            <span class="label">{{ mount.mount }}:</span>
                            <span class="value">{{ (mount.size_total / 1024 / 1024 / 1024) | round(1) }} GB</span>
                        </p>
                    {% endfor %}
                    {% if ansible_mounts | length > 3 %}
                        <p>... и еще {{ ansible_mounts | length - 3 }} точек</p>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="footer">
            <p>🔄 Информация обновлена: {{ ansible_date_time.date }} {{ ansible_date_time.time }}</p>
            <p>🤖 Управляется с помощью Ansible | Веб-сервер Apache</p>
            <p>📊 Данные получены через Ansible facts</p>
        </div>
    </div>
</body>
</html>
